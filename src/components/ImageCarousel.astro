---
interface Props {
  images: string[];
}

const { images } = Astro.props;
---

<section class="carousel" aria-label="Cabin gallery">
  <div class="carousel-shell" data-carousel>
    <button type="button" class="carousel-btn carousel-btn-prev" data-prev aria-label="Previous image">←</button>
    <div class="carousel-stage" data-stage>
      {images.map((image, index) => (
        <figure class="carousel-item" data-item data-index={index} aria-label={`Gallery image ${index + 1}`}>
          <img src={image} alt="Bush Baby cabin and surroundings" loading="lazy" />
        </figure>
      ))}
    </div>
    <button type="button" class="carousel-btn carousel-btn-next" data-next aria-label="Next image">→</button>
  </div>
  <div class="carousel-dots" data-dots aria-label="Carousel pagination"></div>
</section>

<script>
  const root = document.currentScript?.closest('[data-carousel]')?.parentElement;
  const carousel = root?.querySelector('[data-carousel]');
  const stage = root?.querySelector('[data-stage]');
  const prev = root?.querySelector('[data-prev]');
  const next = root?.querySelector('[data-next]');
  const dotsRoot = root?.querySelector('[data-dots]');
  const cards = Array.from(root?.querySelectorAll('[data-item]') ?? []);

  if (!carousel || !stage || !prev || !next || !cards.length) {
    // No carousel to initialize
  } else {
    let activeIndex = 0;
    let touchStartX = 0;

    const toWrappedPosition = (index) => {
      const count = cards.length;
      const raw = (index - activeIndex + count) % count;
      return raw > count / 2 ? raw - count : raw;
    };

    const render = () => {
      cards.forEach((card, index) => {
        const position = toWrappedPosition(index);
        card.dataset.pos = String(position);
        const isVisible = Math.abs(position) <= 2;
        card.classList.toggle('is-active', position === 0);
        card.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
      });

      if (dotsRoot) {
        dotsRoot.innerHTML = '';
        cards.forEach((_, index) => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = `carousel-dot${index === activeIndex ? ' is-active' : ''}`;
          dot.setAttribute('aria-label', `Go to image ${index + 1}`);
          dot.addEventListener('click', () => goTo(index));
          dotsRoot.appendChild(dot);
        });
      }
    };

    const goTo = (nextIndex) => {
      activeIndex = (nextIndex + cards.length) % cards.length;
      render();
    };

    prev.addEventListener('click', () => goTo(activeIndex - 1));
    next.addEventListener('click', () => goTo(activeIndex + 1));

    stage.addEventListener('touchstart', (event) => {
      touchStartX = event.touches[0]?.clientX ?? 0;
    }, { passive: true });

    stage.addEventListener('touchend', (event) => {
      const touchEndX = event.changedTouches[0]?.clientX ?? 0;
      const delta = touchEndX - touchStartX;
      if (Math.abs(delta) < 30) return;
      goTo(activeIndex + (delta < 0 ? 1 : -1));
    });

    render();
  }
</script>
