---
import { siteConfig } from '../config/site';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="wordmark">{siteConfig.businessName}</p>
      <p>{siteConfig.descriptor}</p>
      <p>{siteConfig.location}</p>
      <div class="tags"><span>Private stay</span><span>Secure enquiry</span></div>
    </div>
    <div>
      <h3>Quick Links</h3>
      <ul>
        {siteConfig.navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h3>Contact</h3>
      <ul>
        <li><a href={`tel:${siteConfig.contact.phoneLink}`}>{siteConfig.contact.phoneDisplay}</a></li>
        <li><a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></li>
        <li><a href={siteConfig.contact.whatsappLink}>WhatsApp</a></li>
      </ul>
    </div>
  </div>
</footer>
