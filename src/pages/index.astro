import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DesktopHome from '../components/home/DesktopHome.astro';
import MobileHome from '../components/home/MobileHome.astro';
---

<BaseLayout title="Bush Baby | A Private Nature Escape in Sabie" description="Bush Baby is a warm, private self-catering cabin in Sabie designed for peaceful weekends and nature-filled stays." canonicalPath="/">
  <Header />
  <main>
    <div class="desktop-only">
      <DesktopHome />
    </div>
    <div class="mobile-only">
      <MobileHome />
    </div>
  </main>
  <Footer />
</BaseLayout>
